# Dokploy Environment Configuration
# Copy this file to .env and customize the values

# Dokploy Configuration
NODE_ENV=production
DOKPLOY_HOST=localhost
DOKPLOY_PORT=3000
JWT_SECRET=your-super-secret-jwt-key-change-this
ENCRYPTION_KEY=your-32-character-encryption-key

# Database Configuration
POSTGRES_DB=dokploy
POSTGRES_USER=postgres
POSTGRES_PASSWORD=dokploy123
POSTGRES_PORT=5432
DATABASE_URL=postgresql://postgres:dokploy123@dokploy-db:5432/dokploy?schema=public

# Redis Configuration
REDIS_PORT=6379
REDIS_URL=redis://dokploy-redis:6379

# Traefik Configuration
TRAEFIK_PORT=80
TRAEFIK_SSL_PORT=443
TRAEFIK_SSL_ENABLED=true
TRAEFIK_ACME_EMAIL=admin@example.com

# Docker Configuration
DOCKER_NETWORK=dokploy-network

# Security (CHANGE THESE!)
DOKPLOY_ADMIN_EMAIL=admin@example.com
DOKPLOY_ADMIN_PASSWORD=admin123