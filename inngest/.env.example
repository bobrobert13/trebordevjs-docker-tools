# Inngest Environment Configuration
# Copy this file to .env and customize the values

# Inngest Version
INNGEST_VERSION=latest

# Environment (dev/prod)
INNGEST_ENV=dev
INNGEST_DEV=1

# Domain Configuration
INNGEST_DOMAIN=inngest.localhost
INNGEST_PORT=8288
INNGEST_CONNECT_PORT=8289
INNGEST_UI_ENABLED=true

# Security Keys (GENERATE SECURE KEYS FOR PRODUCTION!)
# Generate with: openssl rand -hex 32
INNGEST_EVENT_KEY=your-event-key-here-hex-64-chars
INNGEST_SIGNING_KEY=your-signing-key-here-hex-64-chars  
INNGEST_MASTER_KEY=your-master-key-here-hex-64-chars

# Worker Configuration
INNGEST_WORKER_URL=http://localhost:3000/api/inngest
WORKER_HOST=0.0.0.0
WORKER_PORT=3000
WORKER_ENV=development
INNGEST_BASE_URL=http://inngest:8288

# Database Configuration
INNGEST_DB_NAME=inngest
INNGEST_DB_USER=inngest
INNGEST_DB_PASSWORD=inngest123
INNGEST_DB_PORT=5433
INNGEST_POSTGRES_URI=postgresql://inngest:inngest123@inngest-db:5432/inngest?sslmode=disable

# Redis Configuration
INNGEST_REDIS_PORT=6380
INNGEST_REDIS_URI=redis://inngest-redis:6379

# Performance Tuning
INNGEST_QUEUE_WORKERS=100
INNGEST_EXECUTION_BATCH_SIZE=100
INNGEST_MAX_CONCURRENT_EXECUTIONS=1000

# Logging and Monitoring
INNGEST_LOG_LEVEL=info
INNGEST_METRICS_ENABLED=true
INNGEST_TRACING_ENABLED=false
INNGEST_SENTRY_DSN=

# Rate Limiting
INNGEST_RATE_LIMIT_MAX=1000
INNGEST_RATE_LIMIT_REFILL=100
INNGEST_RATE_LIMIT_INTERVAL=1s

# Event Configuration
INNGEST_EVENT_API_URL=
INNGEST_EVENT_KEY_FALLBACK=

# Infrastructure Versions
POSTGRES_VERSION=15-alpine
REDIS_VERSION=7-alpine