# PostHog Environment Configuration
# Copy this file to .env and customize the values

# PostHog Version
POSTHOG_VERSION=latest

# Domain Configuration
POSTHOG_DOMAIN=posthog.localhost
POSTHOG_SITE_URL=http://posthog.localhost:8000
POSTHOG_PORT=8000
POSTHOG_DEBUG=0
POSTHOG_DEMO=0

# Security (CHANGE THESE FOR PRODUCTION!)
# Generate with: openssl rand -hex 32
POSTHOG_SECRET_KEY=your-super-secret-key-change-this-to-something-secure

# Database Configuration
POSTHOG_DB_NAME=posthog
POSTHOG_DB_USER=posthog
POSTHOG_DB_PASSWORD=posthog123
POSTHOG_DB_PORT=5434
POSTHOG_DATABASE_URL=postgresql://posthog:posthog123@posthog-db:5432/posthog

# Redis Configuration
POSTHOG_REDIS_HOST=posthog-redis
POSTHOG_REDIS_PORT=6381
POSTHOG_REDIS_URL=redis://posthog-redis:6379/0
REDIS_CELERY_BROKER_URL=redis://posthog-redis:6379/1
CELERY_RESULT_BACKEND=redis://posthog-redis:6379/2

# ClickHouse Configuration
CLICKHOUSE_VERSION=23.8
CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_DATABASE=posthog
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_CLUSTER=posthog
CLICKHOUSE_REPLICATION=true
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_NATIVE_PORT=9000

# Kafka Configuration
KAFKA_VERSION=3.5
KAFKA_URL=kafka:9092
KAFKA_HOSTS=kafka:9092
KAFKA_PORT=9092
KAFKA_INTERNAL_PORT=9093
KAFKA_CLIENT_CERT_B64=
KAFKA_CLIENT_CERT_KEY_B64=
KAFKA_TRUSTED_CERT_B64=
KAFKA_SECURITY_PROTOCOL=PLAINTEXT
KAFKA_SASL_MECHANISM=PLAIN
KAFKA_SASL_USER=
KAFKA_SASL_PASSWORD=

# Zookeeper Configuration
ZOOKEEPER_VERSION=3.8
ZOOKEEPER_PORT=2181

# MinIO Object Storage Configuration
MINIO_VERSION=latest
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
OBJECT_STORAGE_ENABLED=true
OBJECT_STORAGE_ENDPOINT=http://minio:9000
OBJECT_STORAGE_ACCESS_KEY_ID=minioadmin
OBJECT_STORAGE_SECRET_ACCESS_KEY=minioadmin
OBJECT_STORAGE_BUCKET=posthog
OBJECT_STORAGE_MEDIA_BUCKET=posthog-media
OBJECT_STORAGE_SESSION_RECORDING_BUCKET=posthog-session-recordings

# Email Configuration (Optional)
EMAIL_ENABLED=false
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=true
DEFAULT_FROM_EMAIL=

# Security Configuration
ALLOWED_IP_BLOCKS=
TRUSTED_PROXIES=
SECURE_COOKIES=true

# Analytics and Performance
PRIMARY_DB=clickhouse
EVENT_PROPERTY_USAGE_INTERVAL_SECONDS=86400
EVENT_NAMES_CACHE_DURATION=300
CAPTURE_INTERNAL_METRICS=false
CAPTURE_TIME_TO_SEE_DATA=false
SESSION_RECORDING_KAFKA_PARTITIONS=1
SESSION_RECORDING_KAFKA_TOPIC_NAME=clickhouse_session_recording_events

# Monitoring and Debugging
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.1

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_BURST=100
RATE_LIMIT_RATE=10

# Workers Configuration
CELERY_WORKER_CONCURRENCY=2
CELERY_WORKER_MAX_TASKS_PER_CHILD=1000
CELERY_WORKER_POOL=prefork

# Async Migrations
ASYNC_MIGRATIONS_DISABLE_AUTO_RUN=false
ASYNC_MIGRATIONS_AUTO_CONTINUE=true

# Plugins
PLUGINS_INSTALL_VIA_API=true
PLUGINS_RELOAD_PLUGINS=true

# Temporal Configuration (Optional)
TEMPORAL_VERSION=1.20
TEMPORAL_PORT=7233

# Instance Settings
INSTANCE_PREFERENCES=
CLOUD_DEPLOYMENT=self-hosted

# Infrastructure Versions
POSTGRES_VERSION=15-alpine
REDIS_VERSION=7-alpine